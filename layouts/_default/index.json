{{- $pages := where .Site.Pages "Kind" "page" -}}
[
{{- range $i, $p := $pages -}}
{{- if gt $i 0 }},{{ end -}}
{
  "title": {{ $p.Title | jsonify }},
  "permalink": {{ $p.Permalink | jsonify }},
  "summary": {{ $p.Summary | plainify | jsonify }},
  "content": {{ $p.Plain | truncate 500 | jsonify }},
  "tags": {{ $p.Params.tags | jsonify }},
  "section": {{ $p.Section | jsonify }}
}
{{- end -}}
]
